---
interface Props {
  name: string;
  collection: [string, string][];
  value: any;
}
const { name, collection, value: currentValue } = Astro.props;
---

{
  collection.map(([text, value]) => (
    <>
      <input
        type="radio"
        id={`${name}_${value.toLowerCase()}`}
        name={name}
        value={value}
        checked={value == currentValue}
      />
      <label for={`${name}_${value.toLowerCase()}`}>{text}</label>
    </>
  ))
}
