---
import I18n from "i18next";
import { buildPageLink } from "./common";
interface Props {
  page: number;
}
const { page } = Astro.props;
---

<span class="next">
  <a
    rel="next"
    href={buildPageLink(Astro, page + 1)}
    set:html={I18n.t("views.pagination.next", "Next &rsaquo;")}
  />
</span>
